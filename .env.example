# --------------------------------------------------
# Application
# --------------------------------------------------
APP_NAME=Pliris BA Bot
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# --------------------------------------------------
# Public guest access — server-side only
# --------------------------------------------------
# Required when APP_ENV=production. The same value is configured only in
# the server-rendered Streamlit process and the FastAPI process.
GUEST_UI_SHARED_SECRET=replace_with_a_long_random_secret
GUEST_REQUEST_WINDOW_SECONDS=60
GUEST_REQUESTS_PER_WINDOW=5
GUEST_MAX_REQUESTS_PER_SESSION=40
GUEST_SESSION_RETENTION_SECONDS=86400

# --------------------------------------------------
# OpenAI — server-side only
# --------------------------------------------------
OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_CHAT_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# --------------------------------------------------
# Hosted Supabase
# --------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=replace_with_publishable_key
SUPABASE_SECRET_KEY=replace_with_secret_key
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:replace_with_url_encoded_password@your-session-pooler-host:5432/postgres
SUPABASE_STORAGE_BUCKET=knowledge-base

# --------------------------------------------------
# Database pool
# --------------------------------------------------
POSTGRES_POOL_MIN_SIZE=0
POSTGRES_POOL_MAX_SIZE=5
POSTGRES_CONNECT_TIMEOUT_SECONDS=15

# --------------------------------------------------
# Retrieval baseline
# --------------------------------------------------
RETRIEVAL_MATCH_COUNT=8
RETRIEVAL_CANDIDATE_COUNT=32
FULL_TEXT_WEIGHT=1.0
SEMANTIC_WEIGHT=1.0
RRF_K=50
ENABLE_QUERY_REWRITING=true
ENABLE_RERANKING=true

# --------------------------------------------------
# Guardrails
# --------------------------------------------------
ENABLE_SCOPE_GUARDRAIL=true
SCOPE_CONFIDENCE_THRESHOLD=0.75
OUT_OF_SCOPE_MESSAGE=Pliris BA Bot is designed to assist with Business Analysis, Business Systems Analysis, and Project Management practices. Please ask a question related to one of these areas.

# --------------------------------------------------
# Ingestion
# --------------------------------------------------
PRIVATE_DOCUMENT_DIRECTORY=data/private
CORPUS_MANIFEST_PATH=data/corpus_manifest.yaml
CHUNK_SIZE_TOKENS=700
CHUNK_OVERLAP_TOKENS=100

# --------------------------------------------------
# Monitoring
# --------------------------------------------------
ENABLE_MONITORING=true
ENABLE_FEEDBACK=true
